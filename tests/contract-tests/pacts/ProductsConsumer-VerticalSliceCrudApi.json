    {
      "description": "a request to list all products",
      "providerStates": [
        {
          "name": "a product exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/products"
      },
      "response": {
        "body": {
          "items": [
            {
              "id": "e2490de5-5bd3-43d5-b7c4-526e33f71304",
              "name": "Widget Pro",
              "price": 29.99,
              "stock": 100
            }
          ],
          "totalCount": 1
        },
        "generators": {
          "body": {
            "$.items[*].id": {
              "type": "Uuid"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.items": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.items[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.items[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.items[*].price": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "decimal"
                }
              ]
            },
            "$.items[*].stock": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.totalCount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
