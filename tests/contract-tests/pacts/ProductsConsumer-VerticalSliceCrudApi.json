{
  "consumer": {
    "name": "ProductsConsumer"
  },
  "interactions": [
    {
      "description": "a request to create a product",
      "providerStates": [
        {
          "name": "no products exist"
        }
      ],
      "request": {
        "body": {
          "description": "A professional widget",
          "name": "Widget Pro",
          "price": 29.99,
          "stock": 100
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/products"
      },
      "response": {
        "body": {
          "createdAt": "2026-01-15T10:00:00.0000000Z",
          "description": "A professional widget",
          "id": "e2490de5-5bd3-43d5-b7c4-526e33f71304",
          "name": "Widget Pro",
          "price": 29.99,
          "stock": 100
        },
        "generators": {
          "body": {
            "$.id": {
              "type": "Uuid"
            }
          }
        },
        "headers": {
          "Content-Type": "application/json; charset=utf-8"
        },
        "matchingRules": {
          "body": {
            "$.createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss.SSSSSSS'Z'",
                  "match": "datetime"
                }
              ]
            },
            "$.description": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.price": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "decimal"
                }
              ]
            },
            "$.stock": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
