# Pact Broker configuration
# Copy this file to .env and fill in your values

# URL of your Pact Broker instance
PACT_BROKER_BASE_URL=http://localhost:9292

# Pact Broker authentication (if enabled)
PACT_BROKER_TOKEN=

# Application version (used when publishing pacts)
# In CI, use the git commit SHA: git rev-parse --short HEAD
APP_VERSION=local

# Consumer application name
PACT_CONSUMER=ProductsConsumer

# Provider application name
PACT_PROVIDER=VerticalSliceCrudApi

# Port where the .NET API is running for provider verification
# Default matches src/VerticalSliceCrud.Api/Properties/launchSettings.json
API_PORT=5055

# Mock server port used during consumer tests (Pact mock)
PACT_MOCK_PORT=4000
